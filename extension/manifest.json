{
  "manifest_version": 3,
  "name": "Arabic Converter",
  "version": "1.1.0",
  "description": "Convert Tunisian Arabic (Latin/Arabizi) into Arabic script or Modern Standard Arabic (Fusha).",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Arabic Converter",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"]
}
